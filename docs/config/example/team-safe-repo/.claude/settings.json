{
  "$schema": "https://code.claude.com/schemas/settings.json",
  "description": "Team defaults for a secure Claude Code workspace",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "command": ".claude/hooks/security-check.sh"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "command": ".claude/hooks/auto-format.sh"
      }
    ]
  },
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write"
    ],
    "ask": [
      "Bash(git *)",
      "Bash(npm *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(dd *)",
      "Bash(mkfs.*)"
    ]
  }
}
